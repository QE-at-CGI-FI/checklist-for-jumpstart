# Server
PORT=3001
FRONTEND_URL=http://localhost:5173

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=golf_trip_planner
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret

# Google Places API (for golf course search, ratings, opening hours)
# Get key at: https://console.cloud.google.com — enable "Places API"
GOOGLE_PLACES_API_KEY=your_google_places_api_key

# Mapbox (travel distance & duration between courses)
# Get token at: https://account.mapbox.com
MAPBOX_ACCESS_TOKEN=pk.your_mapbox_token

# WeatherAPI.com (forecast for trip dates)
# Free at: https://www.weatherapi.com/signup.aspx
WEATHER_API_KEY=your_weather_api_key

# Booking.com via RapidAPI (hotel search)
# Subscribe at: https://rapidapi.com/tipsters/api/booking-com
RAPIDAPI_KEY=your_rapidapi_key
